<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="imageview.ImageController">
   <children>
      <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="200.0" layoutX="224.0" layoutY="57.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/happy.png" />
         </image>
      </ImageView>
      <Button onAction="#changeImage" layoutX="264.0" layoutY="268.0" mnemonicParsing="false" text="Change" />
   </children>
</AnchorPane>
