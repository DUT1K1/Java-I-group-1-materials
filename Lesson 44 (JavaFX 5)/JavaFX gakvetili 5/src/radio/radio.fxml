<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="radio.RadioController">
   <children>
      <Label layoutX="72.0" layoutY="48.0" text="2 + 2 = ?">
         <font>
            <Font size="37.0" />
         </font>
      </Label>
      <Label fx:id="statusLabel" layoutX="17.0" layoutY="144.0" prefHeight="63.0" prefWidth="246.0" />
      <RadioButton fx:id="a" layoutX="17.0" layoutY="264.0" mnemonicParsing="false" onAction="#pick" text="a) 3">
         <toggleGroup>
            <ToggleGroup fx:id="answer" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="b" layoutX="103.0" layoutY="264.0" mnemonicParsing="false" onAction="#pick" text="b) Kutaisi" toggleGroup="$answer" />
      <RadioButton fx:id="c" layoutX="217.0" layoutY="264.0" mnemonicParsing="false" onAction="#pick" text="c) 4" toggleGroup="$answer" />
   </children>
</AnchorPane>
