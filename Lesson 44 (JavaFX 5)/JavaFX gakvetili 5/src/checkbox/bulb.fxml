<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="290.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="checkbox.BulbController">
   <children>
      <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="200.0" layoutX="70.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/off.png" />
         </image>
      </ImageView>
      <Label fx:id="statusLabel" alignment="CENTER" layoutX="11.0" layoutY="184.0" prefHeight="46.0" prefWidth="269.0" text="Off" textAlignment="CENTER">
         <font>
            <Font size="30.0" />
         </font>
      </Label>
      <CheckBox fx:id="checkBox" layoutX="77.0" layoutY="293.0" mnemonicParsing="false" onAction="#toggle" prefHeight="40.0" prefWidth="137.0" text="ON/OFF">
         <font>
            <Font size="25.0" />
         </font>
      </CheckBox>
   </children>
</AnchorPane>
